# Clawpal v2 Environment Configuration
# Copy this file to .env and fill in your API keys

# ========== Option 1: Replicate ==========

# Replicate API Token (for selfie + video)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_token_here

# ========== Option 2: fal.ai ==========

# fal.ai API Key (for selfie only)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# ========== Option 3: Tencent Hunyuan ==========

# Tencent Cloud API Credentials (for selfie only)
# Get from: https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here

# ========== Optional Settings ==========

# Force specific provider (replicate, fal, or hunyuan)
# If not set, auto-detects based on available API keys
# CLAWPAL_PROVIDER=hunyuan

# Tencent Cloud Region (default: ap-guangzhou)
# TENCENT_REGION=ap-guangzhou
